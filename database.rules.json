{
  "rules": {
    "status": {
      "": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === "
      }
    },
    "artifacts": {
      "": {
        "settings": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "servers": {
          "": {
            ".read": "data.child('members').child(auth.uid).exists() || newData.child('members').child(auth.uid).exists()",
            ".write": "data.child('members').child(auth.uid).exists() || newData.child('members').child(auth.uid).exists()"
          }
        }
      }
    }
  }
}