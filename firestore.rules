rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- ユーティリティ関数 ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGlobalAdmin(appId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/settings/adminList) &&
        (request.auth.token.email in get(/databases/$(database)/documents/artifacts/$(appId)/settings/adminList).data.emails);
    }

    function isListAdmin(appId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/settings/listAdminList) &&
        (request.auth.token.email in get(/databases/$(database)/documents/artifacts/$(appId)/settings/listAdminList).data.emails);
    }

    function isServerAdmin(appId, serverId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)) &&
        (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)).data.serverAdmins
          || isGlobalAdmin(appId));
    }

    function isJoinedServer(appId, serverId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)) &&
        (request.auth.uid in get(/databases/$(database)/documents/artifacts/$(appId)/servers/$(serverId)).data.joinedUsers
          || isGlobalAdmin(appId));
    }

    // --- 各コレクションのルール ---

    match /artifacts/{appId} {

      // 1. 全体設定
      match /settings/{docId} {
        allow read: if isAuthenticated();
        allow write: if isGlobalAdmin(appId);
      }
      // リスト管理者は allowedEmails のみ書き込み可
      match /settings/allowedEmails {
        allow write: if isListAdmin(appId);
      }

      // 招待コードインデックス（コード→サーバーID の逆引き）
      // 認証済みユーザーなら読める、書き込みは認証済みユーザー（内容が正しくなくても実害なし）
      match /inviteIndex/{code} {
        allow get: if isAuthenticated();
        allow create: if isServerAdmin(appId, request.resource.data.serverId);
        allow update: if isServerAdmin(appId, resource.data.serverId) && isServerAdmin(appId, request.resource.data.serverId);
        allow delete: if isServerAdmin(appId, resource.data.serverId);
      }

      // 2. ユーザー情報
      match /users/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // サーバー作成クォータ（本人のみ読み書き）
      match /userQuotas/{qUserId} {
        allow read: if isAuthenticated() && request.auth.uid == qUserId;
        allow write: if false; // クライアントからの直接更新を禁止
      }

      match /users/{userId}/profile/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // E2EE 秘密鍵バックアップ: 本人のみ読み書き可（他者・未認証は一切読めない）
      match /users/{userId}/private/{docId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // 既読状態の同期
      match /users/{userId}/readStates/{docId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // 3. グローバルオンライン状態
      match /status/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // 4. P2P音声通話シグナリング
      match /calls/{callId} {
        allow read: if isAuthenticated() &&
          (resource.data.caller.uid == request.auth.uid ||
           resource.data.callee.uid == request.auth.uid ||
           resource.data.calleeUid == request.auth.uid);
        allow update: if isAuthenticated() &&
          (resource.data.caller.uid == request.auth.uid ||
           resource.data.callee.uid == request.auth.uid ||
           resource.data.calleeUid == request.auth.uid) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['caller', 'callee', 'calleeUid']);
        allow create: if isAuthenticated() &&
          request.resource.data.caller.uid == request.auth.uid;
        match /callerCandidates/{candId} {
          allow read, create: if isAuthenticated() &&
            (get(/databases/$(database)/documents/artifacts/$(appId)/calls/$(callId)).data.caller.uid == request.auth.uid ||
             get(/databases/$(database)/documents/artifacts/$(appId)/calls/$(callId)).data.calleeUid == request.auth.uid);
        }
        match /calleeCandidates/{candId} {
          allow read, create: if isAuthenticated() &&
            (get(/databases/$(database)/documents/artifacts/$(appId)/calls/$(callId)).data.caller.uid == request.auth.uid ||
             get(/databases/$(database)/documents/artifacts/$(appId)/calls/$(callId)).data.calleeUid == request.auth.uid);
        }
      }

      // 4b. P2Pファイル共有シグナリング（本体はP2P。ここはofferやICE候補だけ）
      match /fileshares/{shareId} {
        allow read: if isAuthenticated() &&
          (resource.data.sender.uid == request.auth.uid ||
           resource.data.receiverUid == request.auth.uid);
        allow update: if isAuthenticated() &&
          (resource.data.sender.uid == request.auth.uid ||
           resource.data.receiverUid == request.auth.uid) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sender', 'receiverUid']);
        allow create: if isAuthenticated() &&
          request.resource.data.sender.uid == request.auth.uid;
        allow delete: if isAuthenticated() &&
          (resource.data.sender.uid == request.auth.uid ||
           resource.data.receiverUid == request.auth.uid);
        match /senderCandidates/{candId} {
          allow read, create: if isAuthenticated() &&
            (get(/databases/$(database)/documents/artifacts/$(appId)/fileshares/$(shareId)).data.sender.uid == request.auth.uid ||
             get(/databases/$(database)/documents/artifacts/$(appId)/fileshares/$(shareId)).data.receiverUid == request.auth.uid);
        }
        match /receiverCandidates/{candId} {
          allow read, create: if isAuthenticated() &&
            (get(/databases/$(database)/documents/artifacts/$(appId)/fileshares/$(shareId)).data.sender.uid == request.auth.uid ||
             get(/databases/$(database)/documents/artifacts/$(appId)/fileshares/$(shareId)).data.receiverUid == request.auth.uid);
        }
      }

      // ============================================================
      // サーバーベース構造
      // ============================================================

      match /servers/{serverId} {
        // 単一ドキュメント取得は認証済みユーザー全員に許可（参加時のID検索・パスワード照合のため）
        allow get: if isAuthenticated();
        // 一覧取得はグローバル管理者、または自分が joinedUsers に含まれるドキュメントのみ
        allow list: if isGlobalAdmin(appId) ||
          (isAuthenticated() && request.auth.uid in resource.data.joinedUsers);

        // サーバー作成: 参加者および管理者は作成者（自身）のみに限定する
        allow create: if isAuthenticated() &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.serverAdmins == [request.auth.uid] &&
          request.resource.data.joinedUsers == [request.auth.uid];

        allow update: if (isServerAdmin(appId, serverId) || isGlobalAdmin(appId)) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy']) || resource.data.createdBy == request.auth.uid);

        // 退出操作: 自分自身を joinedUsers/serverAdmins から削除する場合のみ
        allow update: if isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['joinedUsers', 'serverAdmins', 'memberCount']) &&
          request.auth.uid in resource.data.joinedUsers &&
          request.resource.data.joinedUsers == resource.data.joinedUsers.removeAll([request.auth.uid]) &&
          request.resource.data.serverAdmins == resource.data.serverAdmins.removeAll([request.auth.uid]) &&
          request.resource.data.memberCount == resource.data.memberCount - 1;

        // サーバー削除: グローバル管理者またはサーバー管理者
        allow delete: if isGlobalAdmin(appId) || isServerAdmin(appId, serverId);

        // サーバー内の秘密情報（管理者のみ）
        match /secrets/{docId} {
          allow read: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
          allow create, update: if isServerAdmin(appId, serverId);
          allow delete: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);
        }

        // ルーム一覧
        match /rooms/{roomId} {
          allow read: if isJoinedServer(appId, serverId);
          allow create: if isServerAdmin(appId, serverId);
          allow update: if isServerAdmin(appId, serverId) || (
            isJoinedServer(appId, serverId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessageAt', 'lastMessageSender', 'lastMessageText'])
          );
          allow delete: if isServerAdmin(appId, serverId) || isGlobalAdmin(appId);

          // ルーム内メッセージ
          match /messages/{messageId} {
            allow read: if isJoinedServer(appId, serverId);
            allow create: if isJoinedServer(appId, serverId) &&
              request.resource.data.senderId == request.auth.uid;
            allow update: if isJoinedServer(appId, serverId) && (
              (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned']) && isServerAdmin(appId, serverId))
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
              || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned', 'reactions']) && isServerAdmin(appId, serverId))
              || (resource.data.senderId == request.auth.uid
                  && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['senderId', 'createdAt', 'timestamp', 'isPinned']))
              || (isServerAdmin(appId, serverId)
                  && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['senderId', 'createdAt', 'timestamp']))
            );
            allow delete: if isJoinedServer(appId, serverId) &&
              (resource.data.senderId == request.auth.uid || isServerAdmin(appId, serverId));
          }

          // 既読レシート
          match /readReceipts/{receiptUserId} {
            allow read: if isJoinedServer(appId, serverId);
            allow create, update: if isJoinedServer(appId, serverId) &&
              request.auth.uid == receiptUserId;
            allow delete: if isJoinedServer(appId, serverId) &&
              (request.auth.uid == receiptUserId || isServerAdmin(appId, serverId));
          }

          // E2EE ルーム共通鍵（各メンバーの公開鍵で暗号化済み）
          // 参加メンバーなら読み取り可（自分宛の wrapped key を復号するため）。
          // 新規の鍵の作成（配布）は参加メンバーなら許可するが、上書き(update)や削除(delete)はサーバー管理者に限定。
          match /roomKeys/{keyId} {
            allow read: if isJoinedServer(appId, serverId);
            allow create: if isJoinedServer(appId, serverId);
            allow update, delete: if isServerAdmin(appId, serverId);
          }

          // タイピングインジケーター（サーバー参加者のみ）
          match /typing/{userId} {
            allow read: if isJoinedServer(appId, serverId);
            allow write: if isJoinedServer(appId, serverId) && request.auth.uid == userId;
          }
        }

        // サーバー別プロフィール
        match /profiles/{profileUserId} {
          allow read: if isJoinedServer(appId, serverId);
          allow create, update: if isJoinedServer(appId, serverId) &&
            request.auth.uid == profileUserId;
          allow delete: if isJoinedServer(appId, serverId) &&
            (request.auth.uid == profileUserId || isServerAdmin(appId, serverId));
        }

        // 招待コード
        match /inviteCodes/{code} {
          allow read: if isServerAdmin(appId, serverId);
          allow write: if isServerAdmin(appId, serverId);
        }
      }
    }

  }
}
